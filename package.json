{
  "name": "political-arena",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "npm run build && wrangler deploy",
    "data:fec2026:dry-run": "node scripts/prepare-fec-2026-loader.mjs --dry-run",
    "data:fec2026:sql": "node scripts/prepare-fec-2026-loader.mjs",
    "data:governors2026:dry-run": "node scripts/prepare-governor-2026-loader.mjs --dry-run",
    "data:governors2026:sql": "node scripts/prepare-governor-2026-loader.mjs"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "date-fns": "^4.4.0",
    "itty-router": "^5.0.24",
    "jose": "^6.2.3",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.0"
  }
